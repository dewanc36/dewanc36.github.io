---
import { siteConfig } from "../config";

const links = [
  { href: "/", label: "Home" },
  { href: "/work", label: "Experience" },
  { href: "/projects", label: "Projects" },
];

// Normalize the current path (drop trailing slash, but keep "/").
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<header class="nav">
  <div class="container">
    <a class="nav__name" href="/">{siteConfig.name}</a>
    <nav class="nav__links">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={path === link.href ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
