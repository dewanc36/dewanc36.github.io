---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = siteConfig.description } = Astro.props;
const pageTitle = title ? `${title} · ${siteConfig.name}` : siteConfig.name;
const onReading = Astro.url.pathname.startsWith("/reading");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="nav">
      <div class="container">
        <a class="nav__name" href="/">{siteConfig.name}</a>
        <nav class="nav__links">
          <a href="/reading" aria-current={onReading ? "page" : undefined}>
            Today's Reading
          </a>
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
